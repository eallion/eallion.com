{
  "name": "eallion.com",
  "version": "v6.0.2",
  "description": "eallion.com hugo blog theme by pehtheme",
  "private": true,
  "hugo-bin": {
    "buildTags": "extended"
  },
  "scripts": {
    "build": "run-s clean fetch:ghost fetch:stats build:css gen:llms build:hugo build:pagefind",
    "build:chroma": "\\rm -f assets/css/chroma.css && hugo gen chromastyles --style=github | sed 's/\\./html:not(.dark) ./' >> assets/css/chroma.css && hugo gen chromastyles --style=github-dark | sed 's/\\./html.dark ./' >> assets/css/chroma.css",
    "build:css": "cross-env NODE_ENV=production tailwindcss -i ./assets/css/input.css -o ./assets/css/main.css",
    "build:hugo": "hugo --minify --gc",
    "build:pagefind": "pagefind --site public --output-subdir pagefind --force-language zh",
    "clean": "run-p clean:posts clean:data clean:hugo",
    "clean:data": "rimraf ./assets/data/stats",
    "clean:hugo": "rimraf public",
    "clean:posts": "rimraf ./content/blog/*.md",
    "dev": "run-p dev:css dev:hugo",
    "dev:css": "cross-env NODE_ENV=development tailwindcss -i ./assets/css/input.css -o ./assets/css/main.css --watch",
    "dev:hugo": "open-cli http://127.0.0.1:1313 && hugo server -w -D -p 1313 --bind 0.0.0.0 --contentDir content -e production --gc --minify --disableKinds RSS --disableFastRender --renderToMemory --printUnusedTemplates --templateMetrics --templateMetricsHints",
    "dev:pagefind": "pnpm build:css && pnpm build:hugo && pagefind --site public --output-subdir pagefind --force-language zh && open-cli http://127.0.0.1:1414 && npx serve public -l 1414",
    "fetch:ghost": "run-p fetch:ghost:posts fetch:ghost:pages",
    "fetch:ghost:pages": "node scripts/ghost-fetch-pages.js",
    "fetch:ghost:posts": "node scripts/ghost-fetch-posts.js",
    "fetch:stats": "node scripts/fetch-stats.js",
    "gen:llms": "node scripts/generate-llms.js",
    "theme:init": "git submodule update --init --recursive",
    "theme:update": "git submodule update --remote --force themes/pehe"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eallion/eallion.com"
  },
  "keywords": [
    "博客",
    "主题",
    "blog",
    "directus",
    "wordpress",
    "ghost",
    "eallion",
    "hugo-theme",
    "hugo",
    "m3",
    "Mastodon",
    "Material Design",
    "MD3",
    "neodb",
    "Pehe",
    "pehtheme",
    "tailwind",
    "tailwindcss",
    "theme"
  ],
  "author": "Charles Chin",
  "license": "GLWTPL",
  "bugs": {
    "url": "https://github.com/eallion/eallion.com/issues"
  },
  "homepage": "https://github.com/eallion/eallion.com#readme",
  "dependencies": {
    "@tailwindcss/cli": "^4.3.3",
    "@tailwindcss/postcss": "^4.3.3",
    "@tailwindcss/typography": "^0.5.20",
    "axios": "^1.18.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "js-yaml": "^4.3.0",
    "jsonwebtoken": "^9.0.3",
    "npm-run-all": "^4.1.5",
    "pagefind": "^1.5.2",
    "postcss": "^8.5.21",
    "rimraf": "^6.1.3",
    "smol-toml": "^1.7.0",
    "tailwindcss": "^4.3.3",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "open-cli": "^9.0.0"
  }
}
