# Ghost domain (ActivityPub handle: @user@ghost.example.com)
DOMAIN=example.com

# Database settings
DATABASE_ROOT_PASSWORD=reallysecurerootpassword
DATABASE_USER=ghost
DATABASE_PASSWORD=ghostpassword

# Data locations
UPLOAD_LOCATION=./data/ghost
MYSQL_DATA_LOCATION=./data/mysql

# Ghost configuration (https://ghost.org/docs/config/)

# SMTP Email (required for logins, password resets, admin notifications)
mail__transport=SMTP
mail__options__host=smtp.example.com
mail__options__port=465
mail__options__secure=true
mail__options__auth__user=user@example.com
mail__options__auth__pass=password
mail__from="'Support' <support@example.com>"

# 腾讯云 COS 配置
COS_SECRET_ID=your-secret-id
COS_SECRET_KEY=your-secret-key
COS_BUCKET=your-bucket-123456
COS_REGION=ap-shanghai
CDN_URL=https://images.example.com

# --- Multi-site configuration ---
# If using compose.multi.yml, add the following to your .env:
#
# Site2 URL (domain)
# SITE2_URL=https://ghost.site2.com
# Site2 database name (defaults to ghost_site2)
# SITE2_DATABASE_NAME=ghost_site2
# Site2 database password (same as DATABASE_PASSWORD if sharing the MySQL user)
# SITE2_DATABASE_PASSWORD=
# Site2 storage (defaults to local; uncomment to change)
# SITE2_STORAGE=local
# Site2 content data path (defaults to ./data/ghost-site2)
# SITE2_UPLOAD_LOCATION=./data/ghost-site2

# Force Ghost version (optional)
# GHOST_VERSION=6-alpine
